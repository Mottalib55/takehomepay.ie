---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Embed Our Irish Salary Calculator on Your Site | TakeHomePay.ie" description="Get the embed code to add the TakeHomePay.ie Irish salary calculator widget to your website. Free, customizable, and easy to install.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://takehomepay.ie/" },
      { "@type": "ListItem", "position": 2, "name": "Widget", "item": "https://takehomepay.ie/widget/" }
    ]
  })} />

  <div class="max-w-3xl mx-auto">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Widget</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-4">Embed Our Calculator on Your Site</h1>
    <p class="text-gray-600 mb-8">Add the TakeHomePay.ie Irish salary calculator to your website, blog, or intranet. The widget is free to use, responsive, and always up to date with the latest Irish tax rates.</p>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Embed Code</h2>
      <p class="text-gray-700 mb-3">Copy and paste the following HTML code into your website where you want the calculator to appear:</p>
      <div class="bg-gray-900 text-green-400 rounded-lg p-4 overflow-x-auto">
        <pre class="text-sm"><code>&lt;iframe src="https://takehomepay.ie/" width="100%" height="700" frameborder="0" style="border:none;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);" title="Irish Take-Home Pay Calculator"&gt;&lt;/iframe&gt;</code></pre>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Installation Instructions</h2>
      <ol class="list-decimal list-inside space-y-3 text-gray-700">
        <li><strong>Copy the embed code</strong> from the code block above.</li>
        <li><strong>Open your website editor</strong> and navigate to the page where you want to display the calculator. Switch to the HTML or code view if you are using a visual editor.</li>
        <li><strong>Paste the code</strong> at the desired location in your HTML. The iframe will automatically fill the width of its container element.</li>
        <li><strong>Save and publish</strong> your page. The calculator will load directly from TakeHomePay.ie and will always reflect the latest tax rates and features.</li>
      </ol>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Customization Options</h2>
      <p class="text-gray-700 mb-4">You can adjust the following attributes to fit the calculator into your site design:</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left border border-gray-200 rounded-lg overflow-hidden">
          <thead class="bg-gray-100 text-gray-700">
            <tr>
              <th class="px-4 py-3 font-semibold">Attribute</th>
              <th class="px-4 py-3 font-semibold">Default</th>
              <th class="px-4 py-3 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-4 py-3 font-mono text-sm">width</td>
              <td class="px-4 py-3">100%</td>
              <td class="px-4 py-3 text-gray-600">The width of the calculator. Use a percentage for responsive layouts or a fixed pixel value (e.g., "600px").</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono text-sm">height</td>
              <td class="px-4 py-3">700</td>
              <td class="px-4 py-3 text-gray-600">The height of the calculator in pixels. Increase this value if content is cut off, or decrease it for a more compact display.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono text-sm">style</td>
              <td class="px-4 py-3">border:none; ...</td>
              <td class="px-4 py-3 text-gray-600">Inline CSS for additional styling. You can modify the border-radius, box-shadow, or add a border to match your site theme.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Terms of Use</h2>
      <p class="text-gray-700 leading-relaxed">
        The widget is provided free of charge for personal and commercial use. Please do not modify the calculator content within the iframe or attempt to remove attribution. The calculator is served directly from our servers and will always display the most current version. We reserve the right to update the calculator design and functionality at any time.
      </p>
    </section>
  </div>
</Layout>
