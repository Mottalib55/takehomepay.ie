---
interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = 'https://takehomepay.ie';
const pageUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content="en_IE" />
    <meta name="twitter:card" content="summary" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Irish Take-Home Pay Calculator",
      "url": siteUrl,
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
      "description": description,
    })} />
    <script defer data-domain="takehomepay.ie" src="https://plausible.io/js/script.js"></script>
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="min-h-screen bg-surface text-gray-900 font-sans">
    <header class="bg-white border-b border-border">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-primary font-bold text-xl hover:text-primary-dark transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          takehomepay.ie
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a href="/" class="text-gray-600 hover:text-primary transition-colors">Calculator</a>
          <a href="/faq/" class="text-gray-600 hover:text-primary transition-colors">FAQ</a>
        </nav>
      </div>
    </header>
    <main class="max-w-5xl mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="bg-white border-t border-border mt-12">
      <div class="max-w-5xl mx-auto px-4 py-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-gray-600">
          <div>
            <h3 class="font-semibold text-gray-900 mb-3">Tools</h3>
            <ul class="space-y-2">
              <li><a href="/" class="hover:text-primary">Salary Calculator</a></li>
              <li><a href="/faq/" class="hover:text-primary">FAQ</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-3">Official Resources</h3>
            <ul class="space-y-2">
              <li><a href="https://www.revenue.ie" target="_blank" rel="noopener noreferrer" class="hover:text-primary">Revenue.ie</a></li>
              <li><a href="https://www.citizensinformation.ie" target="_blank" rel="noopener noreferrer" class="hover:text-primary">Citizens Information</a></li>
              <li><a href="https://www.gov.ie" target="_blank" rel="noopener noreferrer" class="hover:text-primary">Gov.ie</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-3">Information</h3>
            <ul class="space-y-2">
              <li><a href="/legal/" class="hover:text-primary">Legal Notice</a></li>
              <li><a href="/privacy/" class="hover:text-primary">Privacy Policy</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-gray-200 text-xs text-gray-400">
          <p>Independent, free salary calculator. Results are estimates only. 2026 tax rates.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
